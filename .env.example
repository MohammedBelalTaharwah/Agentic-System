# ==============================================================
# Application Settings
# ==============================================================
APP_ENV=development             # Application environment (development | staging | test | production)
PROJECT_NAME="Web Assistant"    # Human-readable project name
VERSION=1.0.0                   # Application version
DEBUG=true                      # Enable debug mode (disable in production)
PROJECT_ROOT="root/project"

# ==============================================================
# logging settings
# ==============================================================
# Enable debug mode (disable in production)
DEBUG=true

# Log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL="DEBUG"

# Log renderer (console | json) in producttion, use json for better log management and analysis , and for using tools to make dashboards and visualizations of logs, use console for development and debugging purposes
LOG_RENDERER="console"

# Directory for application logs
LOG_DIR="logs"

# Maximum log file size in bytes (10 MB)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep 
LOG_BACKUP_COUNT=10
#  بدناش اياه يكبر كثير عشان ما ياخدش مساحة كبيرة على الهارد بحط limit

